---
layout: layout.njk
pagination:
  data: events
  size: 1
  alias: event
permalink: "/news-events/{{ event.slug }}/"
eleventyComputed:
  title: "{{ event.title }}"
  description: "{{ event.blurb }}"
---
<div class="pagehero" style="background-image:url('{{ event.image }}')">
  <div class="shade"></div>
  <div class="wrap">
    <p class="breadcrumb"><a href="/">Home</a> / <a href="/news-events/">News &amp; Events</a> / {{ event.title }}</p>
    <p class="eyebrow">{{ event.date }}</p>
    <h1>{{ event.title }}</h1>
    <p>{{ event.blurb }}</p>
  </div>
</div>

<section>
  <div class="wrap">
    <div class="prose">
      <p>{{ event.body }}</p>
      <div class="hero-ctas" style="margin-top:32px">
        <a class="btn btn-clay" href="{{ event.ticketUrl }}" rel="noopener">{{ event.ticketLabel }}</a>
        <a class="btn btn-ghost" href="/news-events/">Back to News &amp; Events</a>
      </div>
    </div>
  </div>
</section>
